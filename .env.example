# ─────────────────────────────────────────────────
# Telnyx Demo – Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────

# Your Telnyx API key (Bearer token)
TELNYX_API_KEY=your_telnyx_api_key_here

# Base URL for the Telnyx v2 API
TELNYX_BASE_URL=https://api.telnyx.com/v2

# Application settings
APP_NAME=Telnyx AI Agent API
APP_ENV=development          # development | production
APP_PORT=8000
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Outbound Call / SIP Settings
TELNYX_CONNECTION_ID=your_call_control_connection_id_here
ASSISTANT_ID=your_default_assistant_id_here

# Vobiz SIP Trunk Settings
VOBIZ_SIP_DOMAIN=your_vobiz_sip_domain_here
VOBIZ_USERNAME=your_vobiz_sip_username_here


